// =============================================
// サンプル 02: コメント
// 一行コメント (//) と 複数行コメント (/* */)
// =============================================

@version "0.2.0"
{
  // 一行コメント
  "name": "comment-sample",

  /* 複数行コメント
     JSON では使えないが .aispec では OK */
  "version": "2.0.0",

  "items": [
    1, // インラインコメント
    2,
    /* ブロック */ 3
  ]
}
